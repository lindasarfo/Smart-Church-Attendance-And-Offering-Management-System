<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Church Management System</title>
    <!-- External CSS -->
    <link rel="stylesheet" href="style.css" />
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>

    <!-- ========== LOGIN PAGE ========== -->
    <div class="login-page" id="loginPage">
        <div class="login-box">
            <h1>⛪ Church</h1>
            <p>Sign in to manage your church</p>
            <div class="form-group">
                <label>Username</label>
                <input type="text" id="loginUsername" value="admin" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="loginPassword" value="admin123" />
            </div>
            <button class="btn-login" id="loginBtn">Login</button>
            <a href="#" class="forgot" id="forgotLink">Forgot Password?</a>
            <div id="loginError" class="error-msg"></div>
        </div>
    </div>

    <!-- ========== MAIN APP ========== -->
    <div class="app hidden" id="appContainer">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand"><span>⛪</span> Church</div>
            <nav id="sidebarNav">
                <a class="active" data-page="dashboard">📊 Dashboard</a>
                <a data-page="attendance">📋 Attendance</a>
                <a data-page="finance">💰 Finance</a>
                <a data-page="reports">📄 Reports</a>
                <a data-page="analytics">📈 Analytics</a>
                <a data-page="users" id="usersNavLink" style="display:none;">👥 Users</a>
                <a class="logout" id="logoutBtn">🚪 Logout</a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main">

            <!-- ===== DASHBOARD ===== -->
            <section class="page active" id="page-dashboard">
                <h2>📊 Dashboard</h2>
                <div class="summary-grid" id="dashboardCards">
                    <div class="summary-card"><div class="label">Total Attendance</div><div class="value" id="dashAttend">0</div><div class="sub">all time</div></div>
                    <div class="summary-card"><div class="label">Total Tithe</div><div class="value" id="dashTithe">GH₵0</div><div class="sub">all time</div></div>
                    <div class="summary-card"><div class="label">Total Offering</div><div class="value" id="dashOffering">GH₵0</div><div class="sub">all time</div></div>
                    <div class="summary-card"><div class="label">Total Income</div><div class="value" id="dashIncome">GH₵0</div><div class="sub">tithe + offering</div></div>
                </div>
                <p style="color:#7a6b9a; font-size:14px;">Welcome, <span id="currentUserDisplay">Admin</span>! Here’s your church summary.</p>
            </section>

            <!-- ===== ATTENDANCE ===== -->
            <section class="page" id="page-attendance">
                <h2>📋 Attendance Management</h2>
                <form id="attendanceForm" autocomplete="off">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>📅 Date</label>
                            <input type="date" id="attDate" required />
                        </div>
                        <div class="form-group">
                            <label>👨 Men</label>
                            <input type="number" id="attMen" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>👩 Women</label>
                            <input type="number" id="attWomen" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>🧑 Adult Total</label>
                            <input type="text" id="attAdult" readonly value="0" />
                            <span class="sum-label">auto‑summed</span>
                        </div>
                        <div class="form-group">
                            <label>🧑‍💼 Gentlemen</label>
                            <input type="number" id="attGentlemen" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>👩‍💼 Ladies</label>
                            <input type="number" id="attLadies" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>🧑‍🤝‍🧑 Youth Total</label>
                            <input type="text" id="attYouth" readonly value="0" />
                            <span class="sum-label">auto‑summed</span>
                        </div>
                        <div class="form-group">
                            <label>👦 Boys</label>
                            <input type="number" id="attBoys" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>👧 Girls</label>
                            <input type="number" id="attGirls" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>👶 Children Total</label>
                            <input type="text" id="attChildren" readonly value="0" />
                            <span class="sum-label">auto‑summed</span>
                        </div>
                        <div class="form-group">
                            <label>📊 Grand Total</label>
                            <input type="text" id="attGrand" readonly value="0" />
                            <span class="sum-label">auto‑summed</span>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">💾 Save Attendance</button>
                            <button type="reset" class="btn btn-secondary">🔄 Reset</button>
                        </div>
                    </div>
                </form>
                <hr style="margin: 24px 0; border: none; border-top: 2px dashed #edeaf5;" />
                <h3 style="margin-bottom: 12px;">Recent Attendance Records</h3>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Date</th><th>Men</th><th>Women</th><th>Adult</th>
                                <th>Gent.</th><th>Ladies</th><th>Youth</th>
                                <th>Boys</th><th>Girls</th><th>Children</th>
                                <th>Total</th><th></th>
                            </tr>
                        </thead>
                        <tbody id="attendanceTableBody">
                            <tr><td colspan="12" class="table-empty">No attendance records.</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ===== FINANCE ===== -->
            <section class="page" id="page-finance">
                <h2>💰 Finance Management</h2>
                <form id="financeForm" autocomplete="off">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>📅 Date</label>
                            <input type="date" id="finDate" required />
                        </div>
                        <div class="form-group">
                            <label>💵 Tithe (GH₵)</label>
                            <input type="number" id="finTithe" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>💲 Offering (GH₵)</label>
                            <input type="number" id="finOffering" min="0" value="0" required />
                        </div>
                        <div class="form-group">
                            <label>📊 Total Income</label>
                            <input type="text" id="finTotal" readonly value="0" />
                            <span class="sum-label">auto‑summed</span>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">💾 Save Finance</button>
                            <button type="reset" class="btn btn-secondary">🔄 Reset</button>
                        </div>
                    </div>
                </form>
                <hr style="margin: 24px 0; border: none; border-top: 2px dashed #edeaf5;" />
                <h3 style="margin-bottom: 12px;">Recent Finance Records</h3>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr><th>Date</th><th>Tithe</th><th>Offering</th><th>Total</th><th></th></tr>
                        </thead>
                        <tbody id="financeTableBody">
                            <tr><td colspan="5" class="table-empty">No finance records.</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ===== REPORTS ===== -->
            <section class="page" id="page-reports">
                <h2>📄 Reports</h2>
                <div class="filter-bar">
                    <div class="form-group">
                        <label>From</label>
                        <input type="date" id="reportFrom" />
                    </div>
                    <div class="form-group">
                        <label>To</label>
                        <input type="date" id="reportTo" />
                    </div>
                    <button class="btn btn-primary" id="generateReportBtn">📊 Generate Report</button>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Attendance</th>
                                <th>Tithe (GH₵)</th>
                                <th>Offering (GH₵)</th>
                                <th>Income (GH₵)</th>
                            </tr>
                        </thead>
                        <tbody id="reportBody">
                            <tr><td colspan="5" class="table-empty">Set date range and generate report.</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ===== ANALYTICS ===== -->
            <section class="page" id="page-analytics">
                <h2>📈 Analytics</h2>
                <div class="charts-grid">
                    <div class="chart-box"><h4>📈 Attendance Trend</h4><canvas id="chartAttendTrend"></canvas></div>
                    <div class="chart-box"><h4>💰 Tithe Trend</h4><canvas id="chartTitheTrend"></canvas></div>
                    <div class="chart-box"><h4>💲 Offering Trend</h4><canvas id="chartOfferingTrend"></canvas></div>
                    <div class="chart-box"><h4>📊 Income Trend</h4><canvas id="chartIncomeTrend"></canvas></div>
                </div>
            </section>

            <!-- ===== USERS (Super Admin only) ===== -->
            <section class="page" id="page-users">
                <h2>👥 User Management</h2>
                <div class="user-actions">
                    <button class="btn btn-success" id="addUserBtn">➕ Add Admin</button>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr><th>Username</th><th>Role</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody id="usersTableBody">
                            <tr><td colspan="4" class="table-empty">No users.</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

        </main>
    </div>

    <!-- ========== TOAST ========== -->
    <div class="toast" id="toast"></div>

    <!-- ========== EXTERNAL JAVASCRIPT ========== -->
    <script src="script.js" defer></script>
</body>
</html>